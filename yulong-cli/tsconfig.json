{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["@types/bun", "node"],
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "build.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "data"]
}
